            <apex:pieSeries dataField="data" labelField="name">
                <apex:chartTips 
                labelField="{!funnyString4}" 
                valueField="{!funnyString4}"
                 />
            </apex:pieSeries>
            
        </apex:chart>

        <c:myTestComponent myValue="My component's value" borderColor="red" />


        <!-- CWE 918 because of tainted src -->
