        <!-- CWE 918 because of tainted value -->
        <apex:image 
        id="theImage" 
        value="https://cdn4.iconfinder.com/data/icons/small-n-flat/24/cat-512.png?{!secretValue}" 
        width='50'
        height="55" 
        alt='" =Description of image here>'/> 

