<apex:page controller="exampleCon" docType="html-5.0">
    <apex:form>
        <apex:outputText value="Watch this counter: {!count}" id="counter"/>
        <apex:actionPoller action="{!incrementCounter}" reRender="counter" interval='5' status="pollerStatus"/>
        <apex:input value="{!inputValue}" id="theTextInput" list='" onmouseover="alert(999)" />'/>
    </apex:form>

    <!-- all attributes are safe except the usual on*-->
    <apex:actionStatus id="pollerStatus"  startText=" jachino<b>hello</b>" stopText=" {!funnyString}" lang="{!funnyString}" 
    layout="{!funnyString}"
    stopStyle="{!funnyString}"
    title='"<script>"alert(1)</script>'
    dir="{!funnyString}"
    ></apex:actionStatus> 

        <!-- CWE 80 - height tainted -->
        <apex:chart width="350" height='{!funnyString3}' 
            data="{!pieData}" 
            colorSet='"<script>alert(989)</script>' 
            name='pippo' >
            <apex:pieSeries dataField="data" labelField="name"/>
            <apex:legend position="right"/>

        </apex:chart>

        <!-- CWE 80 - width tainted -->
